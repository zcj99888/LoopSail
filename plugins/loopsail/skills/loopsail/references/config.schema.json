{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LoopSail Configuration v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "kind": {
      "const": "loopsail-config"
    },
    "protected_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification_output_limit_bytes": {
      "type": "integer",
      "minimum": 1,
      "default": 65536
    },
    "event_log_max_bytes": {
      "type": "integer",
      "minimum": 1,
      "default": 5242880
    }
  }
}
