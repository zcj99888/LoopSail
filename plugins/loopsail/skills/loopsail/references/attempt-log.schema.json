{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LoopSail Attempt Log v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "request_id",
    "list_id",
    "task_id",
    "attempt",
    "agent_id",
    "status",
    "failure_code",
    "failure",
    "actual_diff",
    "diff_fingerprint",
    "worker_result_path",
    "event_log_path",
    "verification",
    "commit",
    "experience_recorded",
    "at"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "kind": {
      "const": "attempt-log"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "list_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "agent_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "done",
        "retry",
        "blocked"
      ]
    },
    "failure_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "failure": {
      "type": [
        "string",
        "null"
      ]
    },
    "actual_diff": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "diff_fingerprint": {
      "type": "string"
    },
    "worker_result_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "event_log_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "experience_recorded": {
      "type": "boolean"
    },
    "at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
