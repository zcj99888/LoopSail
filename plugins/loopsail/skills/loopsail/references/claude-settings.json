{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$LOOPSAIL_TOOL_DIR/scripts/guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking loopsail safety policy"
          }
        ]
      }
    ]
  }
}
