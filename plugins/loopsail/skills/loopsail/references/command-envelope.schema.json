{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LoopSail Command Envelope v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "ok",
    "exit_code",
    "at",
    "data",
    "error"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "kind": {
      "const": "command-envelope"
    },
    "ok": {
      "type": "boolean"
    },
    "exit_code": {
      "enum": [
        0,
        2,
        3,
        4
      ]
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": [
        "object",
        "null"
      ]
    },
    "error": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
